# ─────────────────────────────────────────────────────────────────
# Jana Rewards — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service-role key — NEVER expose to browser/client
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Postback Security ─────────────────────────────────────────────
# A long random string — used to authenticate incoming postbacks
# Generate with: openssl rand -hex 32
POSTBACK_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Admin Access ──────────────────────────────────────────────────
# Email that gets access to /admin
ADMIN_EMAIL=admin@yoursite.com

# ── Contact Form (Resend) ─────────────────────────────────────────
# Sign up free at https://resend.com — 3000 emails/month free
# Get your API key from resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# Where contact form messages are sent TO (your support inbox)
CONTACT_EMAIL_TO=support@yoursite.com

# From address — must be a verified domain in Resend
CONTACT_EMAIL_FROM=noreply@yoursite.com

# ── Offerwall App IDs ─────────────────────────────────────────────
# Leave empty to hide that offerwall's tab in /earn

# Monlix: https://monlix.com/publisher → App ID
NEXT_PUBLIC_MONLIX_APP_ID=

# CPALead: https://cpalead.com/dashboard → Campaign ID
NEXT_PUBLIC_CPALEAD_APP_ID=

# AdGate Rewards: https://adgaterewards.com/publisher → App Hash
NEXT_PUBLIC_ADGATE_APP_ID=

# Lootably: https://lootably.com/publishers → Placement ID
NEXT_PUBLIC_LOOTABLY_PID=

# AdscendMedia: https://adscendmedia.com → App ID
NEXT_PUBLIC_ADSCEND_APP_ID=

# ── Offerwall Tracking & Sync ────────────────────────────────────
# AdGem Reporting API — Bearer token from AdGem dashboard
# Used by /api/adgem-sync (hourly cron) to pull completed conversions
ADGEM_API_KEY=

# TimeWall shared secret — set this same value in TimeWall dashboard
# Used to authenticate inbound postbacks at /api/timewall-callback
TIMEWALL_SECRET=

# Cron secret — protects /api/adgem-sync from public access
# Must match the Authorization: Bearer <value> Vercel Cron sends
# Generate with: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Postback URL Template ─────────────────────────────────────────
# Use this in each offerwall's postback/callback settings:
#
# https://YOUR_DOMAIN/api/postback
#   ?user_id={userid}
#   &payout_amount={reward}
#   &offer_name={offer_name}
#   &transaction_id={txn_id}
#
# TimeWall postback URL:
# https://YOUR_DOMAIN/api/timewall-callback
#   ?user_id={SUBID}&payout={REWARD}&transaction_id={TXID}
#   &offer_name={OFFER_NAME}&secret=YOUR_TIMEWALL_SECRET
#   &provider=monlix
#   &secret_key=YOUR_POSTBACK_SECRET_KEY
